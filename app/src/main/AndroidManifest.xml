<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Polls the Tessie cloud API. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Foreground service that runs the poll loop while armed. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- Post the persistent + "navigate" notifications (runtime prompt on Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Read bonded Bluetooth devices and observe the car's presence. -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Legacy Bluetooth permission for reading the device address on API <= 30. -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />

    <!-- CompanionDeviceManager: run in background + start FGS when the car appears. -->
    <uses-permission android:name="android.permission.REQUEST_COMPANION_RUN_IN_BACKGROUND" />
    <uses-permission android:name="android.permission.REQUEST_COMPANION_START_FOREGROUND_SERVICES_FROM_BACKGROUND" />

    <!-- Optional: lets the service launch Waze directly (no notification tap). -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Optional: prompt the user to exempt us from battery optimization. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Self-update: install the downloaded APK from a GitHub Release. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Android 11+ package visibility so we can detect whether Waze is installed. -->
    <queries>
        <package android:name="com.waze" />
    </queries>

    <application
        android:name=".TeslaSyncApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TeslaSync">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.TeslaSync">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground service: the Tessie poll loop. Not exported. -->
        <service
            android:name=".service.DestinationWatcherService"
            android:exported="false"
            android:foregroundServiceType="dataSync|connectedDevice" />

        <!-- CompanionDeviceService: system calls onDeviceAppeared/Disappeared
             for the car's Bluetooth device (auto-arm). Bound by the system. -->
        <service
            android:name=".bluetooth.CarPresenceService"
            android:exported="true"
            android:permission="android.permission.BIND_COMPANION_DEVICE_SERVICE">
            <intent-filter>
                <action android:name="android.companion.CompanionDeviceService" />
            </intent-filter>
        </service>

        <!-- Serves the downloaded update APK to the system installer. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
