<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Polls the Tessie cloud API. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Foreground service that runs the poll loop while armed. We run it as a
         connectedDevice service (the car we auto-arm with over Bluetooth) because that FGS type
         has NO Android-15 time cap — dataSync is capped at ~6h/24h and crashed the app once a
         day's drives totalled 6h ("Time limit already exhausted for foreground service type
         dataSync"). connectedDevice only requires that we hold BLUETOOTH_CONNECT, which we do. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- Post the persistent + "navigate" notifications (runtime prompt on Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- List paired Bluetooth devices + receive the car's connect/disconnect broadcasts. -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Legacy Bluetooth permission for the same on API <= 30. -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />

    <!-- Optional: lets the service launch Waze directly (no notification tap). -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Optional: prompt the user to exempt us from battery optimization. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Self-update: install the downloaded APK from a GitHub Release. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Android 11+ package visibility so we can detect whether Waze is installed. -->
    <queries>
        <package android:name="com.waze" />
    </queries>

    <application
        android:name=".TeslaSyncApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TeslaSync">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.TeslaSync">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground service: the Tessie poll loop. Not exported. -->
        <service
            android:name=".service.DestinationWatcherService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- Auto-arm: the system delivers Bluetooth connect/disconnect broadcasts here even
             when the app isn't running (ACL_* are on the implicit-broadcast exception list).
             Both actions are protected broadcasts (system-only senders), so exported is safe. -->
        <receiver
            android:name=".bluetooth.CarBluetoothReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.bluetooth.device.action.ACL_CONNECTED" />
                <action android:name="android.bluetooth.device.action.ACL_DISCONNECTED" />
            </intent-filter>
        </receiver>

        <!-- Serves the downloaded update APK to the system installer. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
